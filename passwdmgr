#include <windows.h>
#include <wincrypt.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <conio.h>

#pragma comment(lib, "crypt32.lib")

#define VERSION "2.0.0"
#define DATA_FILE "vault.dat"
#define MAX_INPUT 256

/* ================= COLOR ================= */

void print_color(const char *msg, WORD color) {
    HANDLE h = GetStdHandle(STD_OUTPUT_HANDLE);
    SetConsoleTextAttribute(h, color);
    printf("%s\n", msg);
    SetConsoleTextAttribute(h, 7);
}

#define print_green(msg) print_color(msg, 10)
#define print_red(msg) print_color(msg, 12)
#define print_yellow(msg) print_color(msg, 14)

/* ================= HIDDEN INPUT ================= */

void get_hidden_input(char *buffer, size_t size) {
    int i = 0;
    char ch;

    while ((ch = _getch()) != '\r' && i < size - 1) {
        if (ch == '\b' && i > 0) {
            i--;
            printf("\b \b");
        } else if (ch != '\b') {
            buffer[i++] = ch;
            printf("*");
        }
    }

    buffer[i] = '\0';
    printf("\n");
}

/* ================= DPAPI ENCRYPTION ================= */

int encrypt_data(const char *input, DATA_BLOB *encrypted) {
    DATA_BLOB inputBlob;

    inputBlob.pbData = (BYTE*)input;
    inputBlob.cbData = strlen(input) + 1;

    return CryptProtectData(
        &inputBlob,
        L"PWM Secure",
        NULL,
        NULL,
        NULL,
        0,
        encrypted
    );
}

int decrypt_data(DATA_BLOB *encrypted, char *output) {
    DATA_BLOB decrypted;

    if (!CryptUnprotectData(
        encrypted,
        NULL,
        NULL,
        NULL,
        NULL,
        0,
        &decrypted
    )) {
        return 0;
    }

    strcpy(output, (char*)decrypted.pbData);
    LocalFree(decrypted.pbData);
    return 1;
}

/* ================= FILE STORAGE ================= */

void save_entry(const char *name, const char *password) {
    FILE *fp = fopen(DATA_FILE, "ab");
    if (!fp) {
        print_red("Failed to open vault.");
        exit(1);
    }

    DATA_BLOB encrypted;

    if (!encrypt_data(password, &encrypted)) {
        print_red("Encryption failed.");
        fclose(fp);
        return;
    }

    DWORD nameLen = strlen(name) + 1;

    fwrite(&nameLen, sizeof(DWORD), 1, fp);
    fwrite(name, nameLen, 1, fp);

    fwrite(&encrypted.cbData, sizeof(DWORD), 1, fp);
    fwrite(encrypted.pbData, encrypted.cbData, 1, fp);

    LocalFree(encrypted.pbData);
    fclose(fp);

    print_green("Password saved securely.");
}

int find_entry(const char *name, char *output) {
    FILE *fp = fopen(DATA_FILE, "rb");
    if (!fp) return 0;

    while (!feof(fp)) {
        DWORD nameLen;
        if (fread(&nameLen, sizeof(DWORD), 1, fp) != 1) break;

        char storedName[256];
        fread(storedName, nameLen, 1, fp);

        DWORD dataLen;
        fread(&dataLen, sizeof(DWORD), 1, fp);

        BYTE *buffer = (BYTE*)malloc(dataLen);
        fread(buffer, dataLen, 1, fp);

        if (strcmp(storedName, name) == 0) {
            DATA_BLOB blob;
            blob.pbData = buffer;
            blob.cbData = dataLen;

            int result = decrypt_data(&blob, output);
            free(buffer);
            fclose(fp);
            return result;
        }

        free(buffer);
    }

    fclose(fp);
    return 0;
}

/* ================= COMMANDS ================= */

void handle_add(int argc, char *argv[]) {
    if (argc < 3) {
        print_red("Missing name.");
        return;
    }

    char password[MAX_INPUT];

    printf("Enter password: ");
    get_hidden_input(password, sizeof(password));

    save_entry(argv[2], password);
}

void handle_get(int argc, char *argv[]) {
    if (argc < 3) {
        print_red("Missing name.");
        return;
    }

    char output[MAX_INPUT];

    if (find_entry(argv[2], output)) {
        print_green("Password:");
        printf("%s\n", output);
    } else {
        print_red("Entry not found.");
    }
}

/* ================= MAIN ================= */

int main(int argc, char *argv[]) {

    if (argc < 2) {
        printf("PWM Secure v%s\n", VERSION);
        printf("Usage:\n");
        printf("  pwm add <name>\n");
        printf("  pwm get <name>\n");
        return 0;
    }

    if (strcmp(argv[1], "add") == 0) {
        handle_add(argc, argv);
    }
    else if (strcmp(argv[1], "get") == 0) {
        handle_get(argc, argv);
    }
    else {
        print_red("Unknown command.");
    }

    return 0;
}
