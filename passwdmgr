#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <termios.h>
#include <unistd.h>

#define VERSION "1.0.0"
#define DATA_FILE "vault.dat"
#define MAX_INPUT 256
#define XOR_KEY 0x5A

/* ================= COLOR ================= */

void print_green(const char *msg) {
    printf("\033[1;32m%s\033[0m\n", msg);
}

void print_red(const char *msg) {
    printf("\033[1;31m%s\033[0m\n", msg);
}

void print_yellow(const char *msg) {
    printf("\033[1;33m%s\033[0m\n", msg);
}

/* ================= HELP & VERSION ================= */

void print_help() {
    printf("Simple Password Manager\n\n");
    printf("Usage:\n");
    printf("  pwm add <name>     Add a password\n");
    printf("  pwm get <name>     Retrieve password\n");
    printf("  pwm list           List entries\n");
    printf("  pwm --help         Show help\n");
    printf("  pwm --version      Show version\n");
}

void print_version() {
    printf("pwm version %s\n", VERSION);
}

/* ================= INPUT ================= */

void disable_echo() {
    struct termios tty;
    tcgetattr(STDIN_FILENO, &tty);
    tty.c_lflag &= ~ECHO;
    tcsetattr(STDIN_FILENO, TCSANOW, &tty);
}

void enable_echo() {
    struct termios tty;
    tcgetattr(STDIN_FILENO, &tty);
    tty.c_lflag |= ECHO;
    tcsetattr(STDIN_FILENO, TCSANOW, &tty);
}

void get_hidden_input(char *buffer, size_t size) {
    disable_echo();
    fgets(buffer, size, stdin);
    enable_echo();
    printf("\n");

    buffer[strcspn(buffer, "\n")] = 0;
}

/* ================= ENCRYPTION ================= */

void xor_encrypt(char *data) {
    for (int i = 0; data[i] != '\0'; i++) {
        data[i] ^= XOR_KEY;
    }
}

/* ================= FILE OPERATIONS ================= */

FILE* open_file_append() {
    FILE *fp = fopen(DATA_FILE, "a");
    if (!fp) {
        perror("File open failed");
        exit(EXIT_FAILURE);
    }
    return fp;
}

FILE* open_file_read() {
    FILE *fp = fopen(DATA_FILE, "r");
    if (!fp) {
        print_red("No vault found.");
        exit(EXIT_FAILURE);
    }
    return fp;
}

void save_entry(const char *name, const char *password) {
    FILE *fp = open_file_append();
    fprintf(fp, "%s:%s\n", name, password);
    fclose(fp);
}

int find_entry(const char *name, char *output) {
    FILE *fp = open_file_read();
    char line[512];

    while (fgets(line, sizeof(line), fp)) {
        line[strcspn(line, "\n")] = 0;

        char *stored_name = strtok(line, ":");
        char *stored_pass = strtok(NULL, ":");

        if (stored_name && stored_pass && strcmp(stored_name, name) == 0) {
            strcpy(output, stored_pass);
            fclose(fp);
            return 1;
        }
    }

    fclose(fp);
    return 0;
}

void list_entries() {
    FILE *fp = open_file_read();
    char line[512];

    print_yellow("Stored entries:");
    while (fgets(line, sizeof(line), fp)) {
        char *name = strtok(line, ":");
        if (name) {
            printf("  - %s\n", name);
        }
    }

    fclose(fp);
}

/* ================= COMMAND HANDLERS ================= */

void handle_add(int argc, char *argv[]) {
    if (argc < 3) {
        print_red("Missing name.");
        return;
    }

    char password[MAX_INPUT];

    printf("Enter password: ");
    get_hidden_input(password, sizeof(password));

    xor_encrypt(password);
    save_entry(argv[2], password);

    print_green("Password saved.");
}

void handle_get(int argc, char *argv[]) {
    if (argc < 3) {
        print_red("Missing name.");
        return;
    }

    char encrypted[MAX_INPUT];

    if (find_entry(argv[2], encrypted)) {
        xor_encrypt(encrypted);
        print_green("Password found:");
        printf("%s\n", encrypted);
    } else {
        print_red("Entry not found.");
    }
}

/* ================= MAIN ================= */

int main(int argc, char *argv[]) {

    if (argc < 2) {
        print_help();
        return 0;
    }

    if (strcmp(argv[1], "add") == 0) {
        handle_add(argc, argv);
    }
    else if (strcmp(argv[1], "get") == 0) {
        handle_get(argc, argv);
    }
    else if (strcmp(argv[1], "list") == 0) {
        list_entries();
    }
    else if (strcmp(argv[1], "--help") == 0) {
        print_help();
    }
    else if (strcmp(argv[1], "--version") == 0) {
        print_version();
    }
    else {
        print_red("Unknown command.");
        print_help();
    }

    return 0;
}
